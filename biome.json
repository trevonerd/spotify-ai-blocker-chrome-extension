{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "files": {
    "ignoreUnknown": false,
    "maxSize": 1048576,
    "includes": ["src/**/*", "popup/**/*"]
  }
}
