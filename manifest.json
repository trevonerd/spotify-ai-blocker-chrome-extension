{
  "manifest_version": 3,
  "name": "Spotify AI Blocker",
  "version": "0.4.0",
  "description": "Chrome extension that automatically blocks AI-generated artists on Spotify using a community-maintained list.",

  "permissions": ["storage", "contextMenus", "scripting", "tabs", "alarms"],

  "host_permissions": [
    "https://open.spotify.com/*",
    "https://spclient.wg.spotify.com/*",
    "https://raw.githubusercontent.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["src/injector.ts"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "web_accessible_resources": [
    {
      "resources": ["src/page-script.ts"],
      "matches": ["https://open.spotify.com/*"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Spotify AI Artist Blocker"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
